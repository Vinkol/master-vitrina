# ==============================================================================
# ШАБЛОН ПЕРЕМЕННЫХ ОКРУЖЕНИЯ ДЛЯ РАЗРАБОТЧИКОВ (Имя рабочего файла: .env)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. НАСТРОЙКИ БАЗЫ ДАННЫХ POSTGRESQL (Контейнер: twa_postgres)
# ------------------------------------------------------------------------------
# Логин главного пользователя базы данных (придумайте любой, например: postgres)
POSTGRES_USER=postgres

# Пароль для этого пользователя (придумайте сложный, желательно без символов @, :, /)
POSTGRES_PASSWORD=придумайте_пароль

# Имя базы данных, которая автоматически создастся для проекта (например: beauty_db)
POSTGRES_DB=


# ------------------------------------------------------------------------------
# 2. СЕКРЕТЫ БЭКЕНДА FASTAPI
# ------------------------------------------------------------------------------
# Полная строка подключения к базе. Формат: postgresql+asyncpg://ЛОГИН:ПАРОЛЬ@АДРЕС:ПОРТ/ИМЯ_БД
# ВАЖНО: При запуске в Docker вместо localhost пишите `postgres_db` (это имя контейнера базы).
# Значения логина, пароля и имени БД должны строго совпадать с переменными POSTGRES_* выше!
DATABASE_URL=postgresql+asyncpg://postgres:придумайте_сложный_пароль@postgres_db:5432/beauty_tutor_db

# Токен вашего Telegram-бота. Получать в Telegram у официального бота @BotFather
TELEGRAM_BOT_TOKEN=1234567890:Сюда_Вставить_Токен_Из_Бота_Ботфазер

# Ваш личный Telegram ID (или ID администратора). Нужен, чтобы бот знал, куда слать заявки.
# Можно узнать в Telegram через ботов @userinfobot или @ShowJsonBot
ADMIN_TELEGRAM_ID=987654321

# Секретный ключ для шифрования JWT-токенов авторизации. 
JWT_SECRET=сюда_вставить_любую_длинную_случайную_строку_для_безопасности


# ------------------------------------------------------------------------------
# 3. НАСТРОЙКИ ФРОНТЕНДА REACT И ЛЕНДИНГА (Контейнеры: twa_react и twa_landing)
# ------------------------------------------------------------------------------
# URL-адрес, на который фронтенд будет отправлять запросы к бэкенду.
# При локальном запуске через Docker бэкенд открыт на порту 8000.
VITE_API_URL=http://localhost:8000

# URL вашего проекта в Supabase (если используете облако для хранения картинок или авторизации)
# Брать в панели Supabase: Настройки проекта -> API (Project Settings -> API)
VITE_SUPABASE_URL=

# Публичный анонимный ключ Supabase для работы с клиентской стороны
# Брать в панели Supabase: Настройки проекта -> API -> anon public
VITE_SUPABASE_ANON_KEY=сюда_вставить_публичный_анонимный_ключ_supabase
